# GlycemicGPT -- Public cloud deployment configuration
#
# Copy this file to `.env` and fill in the REQUIRED values before running
# `docker compose up -d`.

# =============================================================================
# REQUIRED: Domain and Let's Encrypt email
# =============================================================================

# The domain name where your dashboard will be served.
# A DNS A record for this domain must point at this server's public IP.
DOMAIN=

# Email address used to register with Let's Encrypt.
# Used for certificate expiry notifications. Use a real address.
ACME_EMAIL=

# =============================================================================
# REQUIRED: Database password
# =============================================================================

# PostgreSQL database password. Generate with:  openssl rand -hex 32
POSTGRES_PASSWORD=

# Optional: change the database username and database name (defaults are fine).
# POSTGRES_USER=glycemicgpt
# POSTGRES_DB=glycemicgpt

# =============================================================================
# REQUIRED: Redis password
# =============================================================================

# Redis password. Generate with:  openssl rand -hex 32
REDIS_PASSWORD=

# =============================================================================
# REQUIRED: API secret key
# =============================================================================

# Used to sign authentication tokens. Generate with:  openssl rand -hex 32
SECRET_KEY=

# =============================================================================
# Optional
# =============================================================================

# AI sidecar API key (for the subscription tier).
# Leave blank if you'll configure your own AI provider keys per-user
# in the dashboard (BYOAI mode).
SIDECAR_API_KEY=

# Log level for the AI sidecar (info, warn, error).
# LOG_LEVEL=info

# Log format for the API (json or text).
# LOG_FORMAT=json
