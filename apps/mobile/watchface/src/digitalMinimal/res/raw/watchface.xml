<?xml version="1.0" encoding="utf-8"?>
<!--
  GlycemicGPT Minimal Watch Face (WFF v2)

  Clean, time-forward design:
    [BG + trend]           Compact BG at top
    10:08                  Large centered time
  No graph, no IoB -- just BG and time.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">

    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <Scene backgroundColor="#ff000000">

        <!-- BG (slot 0): compact top center -->
        <ComplicationSlot
            x="75" y="60" width="300" height="80"
            slotId="0"
            displayName="Blood Glucose"
            supportedTypes="SHORT_TEXT LONG_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="300" height="80"/>
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="5" width="300" height="50">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="36" weight="BOLD"
                            color="#ffffffff">
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="0" y="55" width="300" height="25">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="14" weight="NORMAL"
                            color="#ff9CA3AF">
                            <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="LONG_TEXT">
                <PartText x="0" y="10" width="300" height="60">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="32" weight="BOLD"
                            color="#ffffffff">
                            <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="EMPTY"
                primaryProvider="com.glycemicgpt.mobile.debug/com.glycemicgpt.weardevice.complications.BgComplicationDataSource"
                primaryProviderType="SHORT_TEXT"/>
        </ComplicationSlot>

        <!-- Time display: large, centered -->
        <DigitalClock x="0" y="160" width="450" height="140">
            <TimeText format="hh:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                x="0" y="0" width="450" height="140" alpha="255">
                <Variant mode="AMBIENT" target="alpha" value="0"/>
                <Font family="SYNC_TO_DEVICE" size="72" weight="BOLD"
                    color="#ffffffff"/>
            </TimeText>
            <TimeText format="hh:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                x="0" y="0" width="450" height="140" alpha="0">
                <Variant mode="AMBIENT" target="alpha" value="255"/>
                <Font family="SYNC_TO_DEVICE" size="72" weight="THIN"
                    color="#99ffffff"/>
            </TimeText>
        </DigitalClock>

    </Scene>

</WatchFace>
