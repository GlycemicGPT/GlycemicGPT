#!/bin/bash
# Strips AI tool co-author attribution from commit messages.
# Covers all known AI coding tools, not just Claude/Anthropic.
# Install: cp scripts/hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

MSG_FILE="$1"
if [ ! -f "$MSG_FILE" ]; then
    exit 0
fi

# AI tool names (keep in sync with .github/workflows/ci.yml Attribution Check)
AI_TOOLS="[Cc]laude|[Aa]nthropic|[Cc]opilot|[Cc]hat[Gg][Pp][Tt]|[Oo]pen[Aa][Ii]|[Cc]ursor|[Ww]indsurf|[Cc]odeium|[Cc]ode[Ww]hisperer|[Aa]mazon.[Qq]|[Gg]emini|[Jj]et[Bb]rains.[Aa][Ii]|[Tt]abnine|[Ss]ourcegraph|[Cc]ody|[Dd]evin|[Aa]ider|[Cc]odex|\\[bot\\]|noreply@"

# Strip Co-Authored-By lines referencing AI tools
sed -i "/^Co-[Aa]uthored-[Bb]y:.*\(${AI_TOOLS}\)/d" "$MSG_FILE"

# Strip alternative attribution trailer formats
sed -i '/^[Aa]uthored-[Bb]y:/d' "$MSG_FILE"
sed -i '/^[Gg]enerated-[Bb]y:/d' "$MSG_FILE"
sed -i '/^AI-[Gg]enerated-[Bb]y:/d' "$MSG_FILE"

# Remove trailing blank lines left after stripping
while [ "$(tail -c 2 "$MSG_FILE" | od -An -tx1 | tr -d ' ')" = "0a0a" ]; do
    truncate -s -1 "$MSG_FILE"
done
